asta\\\",\\\"type\\\":\\\"Onshore Wind\\\",\\\"developer_owner\\\":\\\"EDF Renewables\\\",\\\"capacity\\\":{\\\"wind_MW\\\":384,\\\"turbines\\\":48,\\\"turbine_rating_MW\\\":8},\\\"construction_window\\\":\\\"2026 start; COD 2028\\\",\\\"status_of_approvals\\\":\\\"Environmental impact statement accepted by SEA in 2024; SEA resolution expected 1Q‑2025. Early‑works earth‑moving permit already granted.\\\",\\\"confidence\\\":\\\"Medium\\\",\\\"sources\\\":[\\\"Power Technology project profile 21‑Oct‑2024\\\",\\\"Company comments at Chilean wind seminar Nov‑2024\\\"]},{\\\"name\\\":\\\"Quebrada Lo Cayo Wind + BESS\\\",\\\"region\\\":\\\"Coquimbo\\\",\\\"type\\\":\\\"Wind + Storage\\\",\\\"developer_owner\\\":\\\"EDF Renewables Chile\\\",\\\"capacity\\\":{\\\"wind_MW\\\":240,\\\"bess_MWh\\\":300,\\\"turbines\\\":30},\\\"investment_USD_million\\\":396,\\\"construction_window\\\":\\\"October 2026 start (contingent on EIA approval)\\\",\\\"status_of_approvals\\\":\\\"Environmental impact assessment filed with SEA Dec‑2024; in citizen‑participation phase. Grid connection contract under negotiation with CDEC‑SING.\\\",\\\"confidence\\\":\\\"Medium‑Low\\\",\\\"sources\\\":[\\\"New Energy Events 06‑Dec‑2024 (citing Renewables Now)\\\"]},{\\\"name\\\":\\\"Caman Wind Farm\\\",\\\"region\\\":\\\"Araucanía\\\",\\\"type\\\":\\\"Onshore Wind\\\",\\\"developer_owner\\\":\\\"Mainstream Renewable Power (ACP Energy fund)\\\",\\\"capacity\\\":{\\\"wind_MW\\\":300},\\\"construction_window\\\":\\\"2H‑2026 re‑start (earth‑works & turbine re‑assembly)\\\",\\\"status_of_approvals\\\":\\\"Original environmental licence (RCA 2018) remains valid; modification to construction schedule approved by SEA Oct‑2024.\\\",\\\"financing\\\":\\\"Original ~USD 400 m project finance from Banco Estado, Santander & KfW‑IPEX (2019); additional contingency facility under negotiation.\\\",\\\"confidence\\\":\\\"High\\\",\\\"sources\\\":[\\\"WindPower Monthly 07‑Nov‑2024\\\",\\\"Company investor call Nov‑2024\\\"]