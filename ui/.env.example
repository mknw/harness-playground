# Copy to `.env` and fill in real values. `.env` is gitignored.

# ----- Neon Auth (Stack Auth) -----
VITE_STACK_PROJECT_ID=''
VITE_STACK_PUBLISHABLE_CLIENT_KEY=''
STACK_SECRET_SERVER_KEY=''

# Email allow-list for real auth (comma-separated; supports `*@domain.com`).
VITE_ALLOWED_EMAILS=''

# ----- LLM providers -----
GROQ_API_KEY=''
OPENAI_API_KEY=''
OPENROUTER_API_KEY=''
ANTHROPIC_API_KEY=''
CEREBRAS_API_KEY=''

# Optional: Postgres connection (Neon). Defaults to local docker compose.
# DATABASE_URL=''

# ----- Dev auth bypass -----
#
# Default 'true' so `pnpm dev` works without a Stack Auth session — the app
# signs you in as the shared mock user `dev-bypass-user`. See
# `ui/src/lib/auth/dev-bypass.ts` for the gate.
#
# This var is gated on `import.meta.env.DEV` and is structurally ignored in
# production builds — Vite replaces DEV with `false` at build time. If this
# var leaks into a prod build, the app warns at startup but does NOT honor it.
#
# How to enable real auth (test the Stack Auth flow locally):
#   1. Set VITE_DEV_BYPASS_AUTH='false' below.
#   2. `pnpm dev` and sign in via /auth/signin with an email listed in
#      VITE_ALLOWED_EMAILS above.
VITE_DEV_BYPASS_AUTH='true'
